rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: audits
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the owner
    //   - url: string (required) - Audited URL
    //   - timestamp: timestamp (required) - Audit time
    //   - score: number (required) - 0-100 score
    //   - auditData: map (required) - Technical data
    //   - aiAnalysis: map (required) - AI insights
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - email: string (required) - User email
    //   - displayName: string (required) - User name
    //   - photoURL: string (optional) - Profile pic
    //   - role: string (required) - 'user' or 'admin'
    //
    // Collection: chats
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the user
    //   - text: string (required) - Message content
    //   - sender: string (required) - 'user' or 'ai'
    //   - timestamp: timestamp (required) - Message time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && (
        (resource != null && request.auth.uid == resource.data.userId) ||
        (request.resource != null && request.auth.uid == request.resource.data.userId)
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "godiglyofficial@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidAudit(data) {
      return data.keys().hasAll(['userId', 'url', 'timestamp', 'score', 'auditData', 'aiAnalysis']) &&
             data.userId == request.auth.uid &&
             data.url is string && data.url.size() < 2048 &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.auditData is map &&
             data.aiAnalysis is map;
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['userId', 'title', 'content', 'status']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() < 200 &&
             data.content is string && data.content.size() < 50000 &&
             data.status in ['draft', 'published'];
    }

    function isValidKeyword(data) {
      return data.keys().hasAll(['userId', 'term']) &&
             data.userId == request.auth.uid &&
             data.term is string && data.term.size() < 100;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'text', 'sender', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() < 5000 &&
             data.sender in ['user', 'ai'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName', 'role']) &&
             data.email is string && data.email.size() < 100 &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.role in ['user', 'admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || (request.auth.token.email == "godiglyofficial@gmail.com" && request.auth.token.email_verified == true));
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /audits/{auditId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidAudit(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
      // Audits are immutable once created
      allow update: if false;
    }

    match /blog_posts/{postId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidBlogPost(request.resource.data);
      allow update: if isDocOwner() && isValidBlogPost(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /keywords/{keywordId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidKeyword(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /chats/{chatId} {
      allow get: if isDocOwner() || isAdmin();
      allow list: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidChatMessage(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
      // Chat messages are immutable
      allow update: if false;
    }
  }
}
